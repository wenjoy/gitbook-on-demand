  "toolchains": {
    "node": "23.11.0 (verified; 24+ recommended for @iota/iota-sdk)",
    "bun": "1.3.6",
    "rust": "1.89.0-nightly",
    "anchor_cli": "0.31.1",
    "solana_cli": "2.3.11",
    "foundry": "1.5.0",
    "aptos_cli": "8.1.0",
    "sui_cli": "1.73.1"
  },
  "verification": {
    "source_repo": "../sb-on-demand-examples",
    "last_verified": "2026-06-12",
    "commands": [
      {
        "id": "rust-common",
        "cwd": "common/rust-feed-creation",
        "command": "cargo check"
      },
      {
        "id": "solana-feeds",
        "cwd": "solana/feeds/basic",
        "command": "cargo build-sbf"
      },
      {
        "id": "solana-randomness",
        "cwd": "solana/randomness/coin-flip",
        "command": "cargo build-sbf"
      },
      {
        "id": "solana-prediction-market",
        "cwd": "solana/prediction-market",
        "command": "cargo build-sbf"
      },
      {
        "id": "evm-price-feeds",
        "cwd": "evm/price-feeds",
        "command": "(bun install || npm install) && ([ -d lib/forge-std ] || forge install foundry-rs/forge-std --no-git) && forge build"
      },
      {
        "id": "evm-randomness-coin-flip",
        "cwd": "evm/randomness/coin-flip",
        "command": "(bun install || npm install) && ([ -d lib/forge-std ] || forge install foundry-rs/forge-std --no-git) && forge build"
      },
      {
        "id": "evm-randomness-pancake-stacker",
        "cwd": "evm/randomness/pancake-stacker",
        "command": "(bun install || npm install) && ([ -d lib/forge-std ] || forge install foundry-rs/forge-std --no-git) && forge build"
      },
      {
        "id": "sui-feeds",
        "cwd": "sui/feeds/basic",
        "command": "npm install && npm run build:testnet"
      },
      {
        "id": "sui-surge-ts",
        "cwd": "sui/surge/basic",
        "command": "npm install && npx tsc --noEmit"
      },
      {
        "id": "solana-surge-ts",
        "cwd": "solana/surge",
        "command": "npm install && npx tsc --noEmit"
      },
      {
        "id": "solana-x402-ts",
        "cwd": "solana/x402",
        "command": "pnpm install --frozen-lockfile || pnpm install && pnpm exec tsc --noEmit"
      },
      {
        "id": "iota-smoke",
        "cwd": "/tmp/sb-sdk-smoke/iota",
        "command": "npm install && npx tsc --noEmit"
      }
    ],
    "notes": [
      "Current TypeScript example manifests are aligned on @switchboard-xyz/on-demand@^3.10.3 and @switchboard-xyz/common@^5.8.2; see observed_example_versions for the full per-package breakdown.",
      "@mysten/sui latest (2.x) is not yet compatible with current docs/examples imports; pinned to 1.38.0.",
      "Solana on-chain examples are aligned on switchboard-on-demand 0.13.0; the advanced Pinocchio example uses pinocchio 0.11.2 and AccountView.",
      "sui/feeds/basic defaults its checked-in Move.toml to testnet. Use explicit build:testnet, build:mainnet, deploy:testnet, and deploy:mainnet scripts when documenting or verifying flows."
    ]
  }
}
